{
  "name": "voltxampere",
  "version": "12.0.0-alpha.19",
  "description": "Professional web-based circuit simulator with full thermal-electrical coupling, AC-MNA analysis, and interactive measurement.",
  "main": "index.html",
  "homepage": "https://voltxampere.com",
  "author": "goksendev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goksendev/VoltXAmpere.git"
  },
  "bugs": {
    "url": "https://github.com/goksendev/VoltXAmpere/issues"
  },
  "keywords": [
    "spice",
    "circuit-simulator",
    "mna",
    "bjt",
    "mosfet",
    "diode",
    "inductor",
    "thermal-runaway",
    "bode-plot",
    "nyquist",
    "web-simulator"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "node src/test-spice/puppeteer-harness.js",
    "dev": "python3 -m http.server 8765",
    "scenarios": "for f in src/test-spice/*-scenarios.js; do echo \"— $f —\"; node \"$f\" || exit 1; done",
    "test:sparse": "node src/test-spice/sparse-dense-differential-scenarios.js",
    "dev:v2": "npm --prefix ui-v2 run dev",
    "build:v2": "npm --prefix ui-v2 run build",
    "install:v2": "npm --prefix ui-v2 install",
    "vercel-build": "npm --prefix ui-v2 ci && npm --prefix ui-v2 run build"
  },
  "dependencies": {
    "puppeteer": "^24.40.0"
  }
}
